<Window x:Class="Cyber_Bot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cyber Security Bot"
        Height="700"
        Width="1000"
        Background="Black">

    <Grid>

        <!-- LOGO -->
        <Image x:Name="logoImage"
               Height="250"
               Width="350"
               HorizontalAlignment="Center"
               VerticalAlignment="Top"
               Margin="0,10,0,0"/>

        <!-- CHAT BOX -->
        <RichTextBox x:Name="chatBox"
                     Margin="20,280,20,100"
                     Background="Black"
                     Foreground="Lime"
                     FontFamily="Consolas"
                     FontSize="14"
                     BorderBrush="Lime"
                     IsReadOnly="True"/>

        <!-- INPUT BOX -->
        <TextBox x:Name="inputBox"
                 Height="40"
                 Margin="20,0,150,20"
                 VerticalAlignment="Bottom"
                 FontSize="14"
                 Background="Black"
                 Foreground="White"
                 BorderBrush="Lime"/>

        <!-- SEND BUTTON -->
        <Button x:Name="sendButton"
                Content="Send"
                Width="100"
                Height="40"
                Margin="0,0,20,20"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Background="Lime"
                Foreground="Black"
                FontWeight="Bold"
                Click="SendButton_Click"/>

    </Grid>
</Window>